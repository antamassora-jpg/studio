
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Untuk kebutuhan prototipe dan demo "Login Cepat", 
      // kita izinkan user anonim bertindak sebagai admin.
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function isScanner() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_scanner/$(request.auth.uid)) ||
        request.auth.token.firebase.sign_in_provider == 'anonymous'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(userId);
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_scanner/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      // Izinkan publik membaca untuk verifikasi, dan admin untuk manajemen penuh
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /public_student_verifications/{cardCode} {
      allow get: if true;
      allow list: if false;
    }

    match /school_settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /attendance_sessions/{sessionId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /attendance_logs/{logId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
