rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ATURAN PENGEMBANGAN: Izinkan semua akses baca dan tulis untuk mempermudah prototyping.
    // Memastikan pengguna dapat melakukan verifikasi, pencarian data, dan melihat log absensi tanpa kendala izin.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
